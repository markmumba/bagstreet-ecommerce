{
  "name": "server",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && bun build src/preview.ts --target=bun --outfile=dist/server.js",
    "dev": "bun --watch run src/index.ts",
    "preview": "RUN_MIGRATIONS_ON_STARTUP=true NODE_ENV=production bun dist/server.js",
    "db:migrate": "bun run src/scripts/migrate.ts",
    "seed:demo": "bun run src/scripts/seed-products.ts",
    "seed:products": "bun run src/scripts/seed-products.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.0",
    "amqplib": "^2.0.1",
    "hono": "^4.12.27",
    "minio": "^8.0.7",
    "nodemailer": "^6.9.16",
    "shared": "workspace:*",
    "sharp": "^0.35.2",
    "uuid": "^13.0.0",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^11.0.0"
  }
}
